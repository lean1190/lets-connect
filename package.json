{
  "name": "lets-connect",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "npm": ">=11.11.0",
    "node": "24.14.1"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:https": "next dev --experimental-https",
    "debug": "next dev --inspect",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "test": "vitest run --coverage --passWithNoTests",
    "types:check": "tsc --skipLibCheck --noEmit",
    "dev:email": "email dev --dir 'src/emails'",
    "supabase:types": "source .env.local && npx supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > src/lib/database/types.ts",
    "supabase:login": "npx supabase login",
    "generate:splash": "tsx scripts/generate-splash-images.ts",
    "generate:icons": "tsx scripts/generate-icons.ts",
    "dependencies:check": "ncu",
    "dependencies:update": "ncu && npm install && npm run lint && npm test && npm audit",
    "upgrade:next": "npx @next/codemod",
    "skills": "SKILLS_NO_TELEMETRY=1 && npx skills add vercel-labs/agent-skills",
    "analyze": "next experimental-analyze",
    "prepare": "husky"
  },
  "dependencies": {
    "@date-fns/utc": "2.1.1",
    "@hookform/resolvers": "5.4.0",
    "@next-safe-action/adapter-react-hook-form": "2.0.6",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-slot": "1.2.5",
    "@react-email/components": "1.0.12",
    "@supabase/ssr": "0.10.3",
    "@supabase/supabase-js": "2.107.0",
    "@tabler/icons-react": "3.44.0",
    "@vercel/analytics": "1.6.1",
    "@vercel/speed-insights": "1.3.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "motion": "12.40.0",
    "next": "16.2.7",
    "next-safe-action": "8.5.3",
    "qr-scanner": "^1.4.2",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "recharts": "3.8.1",
    "resend": "6.12.4",
    "tailwind-merge": "3.6.0",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "3.6.4",
    "@vercel/config": "0.5.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.7",
    "npm-check-updates": "22.2.3",
    "react-email": "6.5.0",
    "sharp": "^0.34.5",
    "supabase": "2.105.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "1.4.0",
    "typescript": "^6",
    "vitest": "4.1.8"
  }
}
